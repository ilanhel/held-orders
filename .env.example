# ───────────────────────────────────────────────────────────
# HELD Orders — environment variables
# Copy to .env.local (dev) or set in your hosting provider (prod).
# NEVER commit real secrets.
# ───────────────────────────────────────────────────────────

# Database — PostgreSQL (Neon, Supabase, Vercel Postgres, …)
# DATABASE_URL = pooled connection used at runtime.
# DIRECT_URL   = direct (non-pooled) connection used for `prisma migrate`.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.neon.tech/db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.neon.tech/db?sslmode=require"

# Session signing secret (JWT / HS256).
# REQUIRED in production — the app refuses to start without it.
# Generate a strong value, e.g.:  openssl rand -base64 48
SESSION_SECRET="change-me-in-production"

# Notification driver: "console" (dev default) | "mock" (tests) | "whatsapp" (prod)
NOTIFICATION_DRIVER="console"

# Demo mode: when "true", the login OTP code is shown on screen instead of
# being sent via WhatsApp/SMS. For shareable TEST links only — never enable
# on a real production deployment.
DEMO_MODE="false"

# WhatsApp Cloud API (only needed when NOTIFICATION_DRIVER=whatsapp)
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BEARER_TOKEN=""
WHATSAPP_API_VERSION="v20.0"

# WhatsApp number of the ERP-intake computer. At end of picking, the order's
# XLSX (barcode + supplied qty) is sent here with one tap from the warehouse.
# May also be a WhatsApp group id (e.g. 120363043968066561@g.us) — useful when
# the sender phone itself must receive the file (WhatsApp can't message itself,
# but it does see messages sent to a group it belongs to).
ERP_INTAKE_PHONE=""

# E2E only: deterministic OTP for Playwright. Ignored when NODE_ENV=production.
# E2E_FIXED_OTP="000000"
